APP_DOMAIN=your-domain.com
APP_DOCS_ENABLED=false
APP_BASE_URL=https://your-domain.com

DB_PASSWORD=please_change_me_use_strong_password

SAIHU_CLIENT_ID=your_client_id
SAIHU_CLIENT_SECRET=your_client_secret

LOGIN_PASSWORD=your_initial_login_password
JWT_SECRET=generate_with_openssl_rand_base64_32

# 进程角色开关由 docker-compose 负责注入，通常无需在这里额外配置

# 第二阶段 GHCR 镜像流水线所需（Phase 2）
# GHCR_OWNER=your_github_username_lowercase
