:8088 {
    encode gzip zstd

    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    request_body {
        max_size 10MB
    }

    handle /api/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    handle /docs* {
        reverse_proxy backend:8000
    }

    handle /openapi.json {
        reverse_proxy backend:8000
    }

    handle /healthz {
        reverse_proxy backend:8000
    }

    handle /readyz {
        reverse_proxy backend:8000
    }

    handle {
        # 禁止 index.html 被浏览器缓存：重建后旧 tab 刷新即可拿到新 hash 的 JS chunk
        @html path / /index.html
        header @html Cache-Control "no-cache, no-store, must-revalidate"
        header @html Pragma "no-cache"
        header @html Expires "0"

        # 带 hash 的静态资源（JS/CSS）保持长缓存（文件名唯一，安全）
        @hashed_assets path /assets/*
        header @hashed_assets Cache-Control "public, max-age=31536000, immutable"

        reverse_proxy frontend:8080
    }

    log {
        output file /data/access.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
    }
}
